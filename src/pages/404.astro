---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404: Page Not Found | YT Downloader" description="The page you are looking for could not be found. Return to the best free YouTube downloader to save videos and MP3s.">
  <!-- Mesh Gradient Background -->
  <div class="fixed inset-0 overflow-hidden pointer-events-none -z-10">
    <div class="absolute top-[10%] left-[-10%] w-[600px] h-[600px] rounded-full bg-gradient-develop-start/20 blur-[100px]"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[500px] h-[500px] rounded-full bg-error/10 blur-[100px]"></div>
  </div>

  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-32 lg:py-40 relative z-10 flex flex-col items-center justify-center min-h-[70vh]">
    <div class="text-center max-w-2xl">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-canvas-soft border border-hairline mb-8 shadow-sm">
        <span class="text-4xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-gradient-develop-start to-gradient-preview-end">404</span>
      </div>
      
      <h1 class="text-4xl md:text-5xl lg:text-[56px] font-semibold text-ink leading-tight tracking-[-1.5px] mb-6">
        Page not found
      </h1>
      
      <p class="text-lg sm:text-xl text-body mb-10 leading-relaxed max-w-lg mx-auto">
        Oops! We couldn't find the page you were looking for. It might have been moved or doesn't exist anymore.
      </p>

      <a href="/" class="inline-flex items-center justify-center h-[48px] px-8 bg-primary text-on-primary rounded-full text-base font-medium hover:bg-ink/90 transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 shadow-sm gap-2">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
        Back to Downloader
      </a>
    </div>
  </div>
</Layout>

---
import Layout from '../layouts/Layout.astro';

interface Props {
    error: unknown
}

const { error } = Astro.props
---

<Layout title="500: Server Error | YT Downloader" description="An unexpected error occurred on our server. Please try again later.">
  <!-- Mesh Gradient Background -->
  <div class="fixed inset-0 overflow-hidden pointer-events-none -z-10">
    <div class="absolute top-[10%] left-[-10%] w-[600px] h-[600px] rounded-full bg-error-deep/10 blur-[100px]"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[500px] h-[500px] rounded-full bg-warning/10 blur-[100px]"></div>
  </div>

  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-32 lg:py-40 relative z-10 flex flex-col items-center justify-center min-h-[70vh]">
    <div class="text-center max-w-2xl w-full">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-error-soft border border-error/20 mb-8 shadow-sm text-error-deep">
        <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
      </div>
      
      <h1 class="text-4xl md:text-5xl lg:text-[56px] font-semibold text-ink leading-tight tracking-[-1.5px] mb-6">
        Internal Server Error
      </h1>
      
      <p class="text-lg sm:text-xl text-body mb-8 leading-relaxed max-w-lg mx-auto">
        Oops! Something went wrong on our end. We're already working on fixing it. Please try again in a few minutes.
      </p>

      {error instanceof Error ? (
        <div class="text-left bg-canvas-soft border border-hairline p-4 rounded-md mb-8 overflow-auto text-sm font-mono text-mute max-h-48 max-w-xl mx-auto shadow-inner">
          <p class="font-bold text-ink mb-1">Error details (for developers):</p>
          <p>{error.message}</p>
        </div>
      ) : null}

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <button onclick="window.location.reload()" class="w-full sm:w-auto inline-flex items-center justify-center h-[48px] px-8 bg-primary text-on-primary rounded-full text-base font-medium hover:bg-ink/90 transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 shadow-sm gap-2">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
          Try Again
        </button>
        <a href="/" class="w-full sm:w-auto inline-flex items-center justify-center h-[48px] px-8 bg-canvas text-ink border border-hairline rounded-full text-base font-medium hover:bg-canvas-soft transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 shadow-sm gap-2">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
          Go to Home
        </a>
      </div>
    </div>
  </div>
</Layout>

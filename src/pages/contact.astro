---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us — YT Downloader" description="Get in touch with the YT Downloader team for support, business inquiries, or feedback.">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12 sm:py-24 w-full">
    <div class="max-w-2xl">
      <h1 class="text-3xl md:text-4xl font-semibold tracking-[-1.28px] text-ink mb-6">Contact Us</h1>
      <p class="text-lg text-body mb-12">Have a question, feedback, or found a bug? We'd love to hear from you. Fill out the form below and our team will get back to you as soon as possible.</p>

      <form class="space-y-6" onsubmit="event.preventDefault(); alert('Thanks for your message! This is a demo form, so no message was actually sent.');">
        <div>
          <label for="name" class="block text-sm font-medium text-ink mb-2">Your Name</label>
          <input type="text" id="name" name="name" required class="w-full h-[48px] bg-canvas border border-hairline rounded-md px-4 text-base text-ink placeholder:text-mute focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none transition-all" placeholder="John Doe" />
        </div>
        
        <div>
          <label for="email" class="block text-sm font-medium text-ink mb-2">Email Address</label>
          <input type="email" id="email" name="email" required class="w-full h-[48px] bg-canvas border border-hairline rounded-md px-4 text-base text-ink placeholder:text-mute focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none transition-all" placeholder="john@example.com" />
        </div>

        <div>
          <label for="subject" class="block text-sm font-medium text-ink mb-2">Subject</label>
          <select id="subject" name="subject" class="w-full h-[48px] bg-canvas border border-hairline rounded-md px-4 text-base text-ink focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none transition-all cursor-pointer">
            <option value="support">General Support</option>
            <option value="bug">Report a Bug</option>
            <option value="business">Business Inquiry</option>
            <option value="feedback">Feedback / Suggestion</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-ink mb-2">Message</label>
          <textarea id="message" name="message" rows="5" required class="w-full bg-canvas border border-hairline rounded-md p-4 text-base text-ink placeholder:text-mute focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none transition-all resize-y" placeholder="How can we help you?"></textarea>
        </div>

        <button type="submit" class="h-[48px] px-8 bg-primary text-on-primary rounded-full text-base font-medium hover:bg-ink/90 transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2">
          Send Message
        </button>
      </form>
    </div>
  </div>
</Layout>

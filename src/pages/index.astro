    const tabAudio = document.getElementById('tab-audio');
    
    if (mode === 'video') {
      tabVideo.className = 'flex-1 py-2 text-sm font-medium rounded-md bg-canvas text-ink shadow-[0_1px_1px_#0000000a] border border-hairline transition-all flex items-center justify-center gap-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary';
      tabAudio.className = 'flex-1 py-2 text-sm font-medium rounded-md text-body hover:text-ink transition-all flex items-center justify-center gap-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary';
      document.getElementById('quality-select').classList.remove('hidden');
      document.getElementById('audio-quality-select').classList.add('hidden');
    } else {
      tabAudio.className = 'flex-1 py-2 text-sm font-medium rounded-md bg-canvas text-ink shadow-[0_1px_1px_#0000000a] border border-hairline transition-all flex items-center justify-center gap-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary';
      tabVideo.className = 'flex-1 py-2 text-sm font-medium rounded-md text-body hover:text-ink transition-all flex items-center justify-center gap-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary';
      document.getElementById('audio-quality-select').classList.remove('hidden');
      document.getElementById('quality-select').classList.add('hidden');
    }
    hideStatus();
  }

  async function pasteUrl() {
    try {
      const text = await navigator.clipboard.readText();
      if (text && (text.includes('youtube') || text.includes('youtu.be'))) {
        document.getElementById('url-input').value = text.trim();
      }
    } catch(e) {
      document.getElementById('url-input').focus();
    }
  }



  function hideStatus() {
    document.getElementById('status-loading').classList.add('hidden');
    document.getElementById('status-success').classList.add('hidden');
    document.getElementById('status-error').classList.add('hidden');
  }

  function showLoading(msg) {
    hideStatus();
    document.getElementById('status-text').textContent = msg || 'Fetching your file…';
    document.getElementById('status-loading').classList.remove('hidden');
  }

  function showSuccess(url, filename) {
    hideStatus();
    const link = document.getElementById('result-link');
    link.href = url;
    link.setAttribute('download', filename || 'download');
    document.getElementById('result-link-text').textContent = 'Click to Download — ' + (filename || 'file');
    document.getElementById('status-success').classList.remove('hidden');
  }

  function showError(msg) {
    hideStatus();
    document.getElementById('error-text').textContent = msg || 'Something went wrong. Please try again.';
    document.getElementById('status-error').classList.remove('hidden');
  }

  async function startDownload() {
    const url = document.getElementById('url-input').value.trim();
    if (!url) { showError('Please paste a YouTube link first.'); return; }
    if (!url.includes('youtube.com') && !url.includes('youtu.be')) {
      showError('That doesn\'t look like a YouTube link. Please check and try again.');
      return;
    }

    const btn = document.getElementById('dl-btn');
    btn.disabled = true;
    showLoading('Contacting download server…');

    const body = {
      url: url,
      downloadMode: currentMode === 'audio' ? 'audio' : 'auto',
      filenameStyle: 'pretty',
    };

    if (currentMode === 'video') {
      body.videoQuality = document.getElementById('quality-select').value;
      body.youtubeVideoCodec = 'h264';
      body.youtubeVideoContainer = 'mp4';
    } else {
      body.audioFormat = 'mp3';
      body.audioBitrate = document.getElementById('audio-quality-select').value;
    }

    try {
      showLoading('Processing your request…');

      const res = await fetch('/api/download', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
        },
        body: JSON.stringify(body),
      });

      const data = await res.json();

      if (data.status === 'tunnel' || data.status === 'redirect') {
        showSuccess(data.url, data.filename);
      } else if (data.status === 'error') {
        const code = data.error?.code || 'unknown';
        if (code.includes('content.too_long')) showError('This video is too long to download.');
        else if (code.includes('fetch.fail')) showError('Could not fetch the video. It may be private or age-restricted.');
        else if (code.includes('rate_limit')) showError('Too many requests. Please wait a moment and try again.');
        else showError('Error: ' + code);
      } else if (data.status === 'picker') {
        if (data.picker && data.picker[0]) {
          showSuccess(data.picker[0].url, 'download');
        } else {
          showError('Could not process this link. Try a direct video URL.');
        }
      } else {
        showError('Unexpected response. Please try again in a moment.');
      }

    } catch (err) {
      if (err.message && err.message.includes('Failed to fetch')) {
        showError('Could not reach the download server. You might be ad-blocked or the API is down.');
      } else {
        showError('Network error: ' + err.message);
      }
    } finally {
      btn.disabled = false;
    }
  }

  document.getElementById('url-input').addEventListener('keydown', e => {
    if (e.key === 'Enter') startDownload();
  });
  document.getElementById('url-input').addEventListener('input', () => {
    hideStatus();
  });

  // Initialize correct mode on load
  setMode('video');
</script>
